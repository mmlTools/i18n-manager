{
  "name": "localesync-i18n",
  "displayName": "LocaleSync: i18n Data Manager",
  "description": "A clean sidebar control panel to manage your i18n translation files. Add keys to every language at once, create new language files, spot missing translations, translate with AI via GitHub Copilot.",
  "version": "1.0.1",
  "publisher": "MMLTECH",
  "homepage": "https://streamrsc.com",
  "pricing": "Free",
  "sponsor": {
    "url": "https://paypal.me/mmltools"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mmlTools/localesync-i18n.git"
  },
  "bugs": {
    "url": "https://github.com/mmlTools/localesync-i18n/issues"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Visualization",
    "Language Packs",
    "Formatters"
  ],
  "keywords": [
    "i18n",
    "internationalization",
    "localization",
    "l10n",
    "translation",
    "translations",
    "json",
    "language",
    "locale",
    "i18next",
    "ai",
    "copilot"
  ],
  "galleryBanner": {
    "color": "#4F46E5",
    "theme": "dark"
  },
  "qna": "marketplace",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "localesync-i18n",
          "title": "i18n Data Manager",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "localesync-i18n": [
        {
          "id": "LocaleSynci18nSidebar",
          "name": "Translations",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "LocaleSynci18n.configureFolder",
        "title": "i18n Data Manager: Configure Translations Folder"
      },
      {
        "command": "LocaleSynci18n.refresh",
        "title": "i18n Data Manager: Refresh"
      }
    ],
    "configuration": {
      "title": "i18n Data Manager",
      "properties": {
        "LocaleSynci18n.translationsPath": {
          "type": "string",
          "default": "",
          "description": "Path to the folder containing translation .json files (relative to the workspace root or absolute)."
        },
        "LocaleSynci18n.defaultLanguage": {
          "type": "string",
          "default": "en",
          "description": "The default / source language code (filename without extension). It will be shown first."
        },
        "LocaleSynci18n.indent": {
          "type": "number",
          "default": 2,
          "description": "Number of spaces used to indent JSON output when writing translation files."
        },
        "LocaleSynci18n.aiTranslate.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show AI translation buttons in the sidebar. Requires an installed VS Code language model provider (e.g. GitHub Copilot). When no provider is available, the buttons are hidden automatically and the rest of the extension works normally."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/vsce": "^2.24.0",
    "eslint": "^8.57.0",
    "typescript": "^5.3.0"
  }
}