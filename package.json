{
  "name": "localesync-i18n",
  "displayName": "LocaleSync: i18n Data Manager",
  "description": "A clean sidebar control panel to manage your i18n translation files. Add keys to every language at once, create new language files, spot missing translations, translate with AI via GitHub Copilot.",
  "version": "1.5.1",
  "publisher": "MMLTECH",
  "homepage": "https://streamrsc.com",
  "pricing": "Free",
  "sponsor": {
    "url": "https://paypal.me/mmltools"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mmlTools/localesync-i18n.git"
  },
  "bugs": {
    "url": "https://github.com/mmlTools/localesync-i18n/issues"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Visualization",
    "Language Packs",
    "Formatters"
  ],
  "keywords": [
    "i18n",
    "internationalization",
    "localization",
    "l10n",
    "translation",
    "translations",
    "json",
    "language",
    "locale",
    "i18next",
    "ai",
    "copilot"
  ],
  "galleryBanner": {
    "color": "#4F46E5",
    "theme": "dark"
  },
  "qna": "marketplace",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "localesync-i18n",
          "title": "i18n Data Manager",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "localesync-i18n": [
        {
          "id": "LocaleSynci18nSidebar",
          "name": "Translations",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "LocaleSynci18n.configureFolder",
        "title": "i18n Data Manager: Configure Translations Folder"
      },
      {
        "command": "LocaleSynci18n.refresh",
        "title": "i18n Data Manager: Refresh"
      },
      {
        "command": "LocaleSynci18n.translateSelection",
        "title": "i18n: Translate Selection…"
      },
      {
        "command": "LocaleSynci18n.createKeyFromSelection",
        "title": "i18n: Create Translation Key from Selection (AI)"
      },
      {
        "command": "LocaleSynci18n.findUnusedKeys",
        "title": "i18n: Find Unused Translation Keys"
      },
      {
        "command": "LocaleSynci18n.renameKeyGlobal",
        "title": "i18n: Rename Translation Key Globally…"
      },
      {
        "command": "LocaleSynci18n.renameNamespace",
        "title": "i18n: Auto Namespace Refactor…"
      },
      {
        "command": "LocaleSynci18n.reviewTranslations",
        "title": "i18n: AI Review Translations…"
      },
      {
        "command": "LocaleSynci18n.showKeyUsages",
        "title": "i18n: Show Key References"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "LocaleSynci18n.translateSelection",
          "when": "editorHasSelection || editorTextFocus",
          "group": "1_modification@99"
        },
        {
          "command": "LocaleSynci18n.createKeyFromSelection",
          "when": "editorHasSelection",
          "group": "1_modification@100"
        },
        {
          "command": "LocaleSynci18n.showKeyUsages",
          "when": "editorTextFocus",
          "group": "1_modification@101"
        }
      ]
    },
    "configuration": {
      "title": "i18n Data Manager",
      "properties": {
        "LocaleSynci18n.translationsPath": {
          "type": "string",
          "default": "",
          "description": "Path to the folder containing translation .json files (relative to the workspace root or absolute)."
        },
        "LocaleSynci18n.defaultLanguage": {
          "type": "string",
          "default": "en",
          "description": "The default / source language code (filename without extension). It will be shown first."
        },
        "LocaleSynci18n.indent": {
          "type": "number",
          "default": 2,
          "description": "Number of spaces used to indent JSON output when writing translation files."
        },
        "LocaleSynci18n.aiTranslate.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show AI translation buttons in the sidebar. Requires an installed VS Code language model provider (e.g. GitHub Copilot). When no provider is available, the buttons are hidden automatically and the rest of the extension works normally."
        },
        "LocaleSynci18n.keyInsertTemplate": {
          "type": "string",
          "default": "${key}",
          "description": "Template used to insert a translation key reference into your code from the 'Translate Selection' command. Use ${key} as the placeholder for the key name."
        },
        "LocaleSynci18n.codeIntegration.hover": {
          "type": "boolean",
          "default": true,
          "description": "Show a hover preview of every language when you hover a translation key in your code."
        },
        "LocaleSynci18n.codeIntegration.codeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show a CodeLens above translation-key call sites with the default-language value inline."
        },
        "LocaleSynci18n.codeIntegration.diagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Warn when a translation key referenced in code is missing or empty in some language files."
        },
        "LocaleSynci18n.codeIntegration.hardcodedDetection": {
          "type": "boolean",
          "default": true,
          "description": "Detect hardcoded UI strings in your source code and offer to extract them into translation keys."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^8.57.0",
    "typescript": "^5.3.0"
  }
}
